{
    "name": "pihole-in-one",
    "version": "1.2.5",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "zip": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "postinstall": "wxt prepare",
        "scripts": "node scripts/run.mjs",
        "intl:extract": "formatjs extract \"src/entrypoints/popup/**/*.{vue,ts}\" \"src/entrypoints/background.ts\" --ignore \"src/**/*.d.ts\" --out-file src/locales/en-US/popup.json --preserve-whitespace && formatjs extract \"src/entrypoints/options/**/*.{vue,ts}\" \"src/components/**/*.vue\" \"src/composables/**/*.ts\" --ignore \"src/**/*.d.ts\" --out-file src/locales/en-US/options.json --preserve-whitespace",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "release:patch": "pnpm version patch && git push && git push --tags",
        "release:minor": "pnpm version minor && git push && git push --tags",
        "release:major": "pnpm version major && git push && git push --tags"
    },
    "dependencies": {
        "@fontsource-variable/inter": "^5.2.8",
        "@formatjs/intl": "^4.1.12",
        "@lucide/vue": "latest",
        "vue": "^3.5.34",
        "vue-i18n": "^11.4.4",
        "vue-router": "^5.0.7"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@formatjs/cli": "^6.16.3",
        "@tailwindcss/vite": "^4.3.0",
        "@types/node": "^25.9.1",
        "@wxt-dev/module-vue": "^1.0.3",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-vue": "^10.9.1",
        "prettier": "^3.8.3",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.4",
        "vite-svg-loader": "^5.1.1",
        "vue-eslint-parser": "^10.4.0",
        "vue-tsc": "^3.3.1",
        "wxt": "^0.20.26"
    },
    "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215"
}
