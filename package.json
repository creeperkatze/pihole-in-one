{
    "name": "pihole-in-one",
    "version": "1.2.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "zip": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "postinstall": "wxt prepare",
        "scripts": "node scripts/run.mjs",
        "intl:extract": "formatjs extract \"src/entrypoints/popup/**/*.{vue,ts}\" \"src/entrypoints/background.ts\" --ignore \"src/**/*.d.ts\" --out-file src/locales/en-US/popup.json --preserve-whitespace && formatjs extract \"src/entrypoints/options/**/*.{vue,ts}\" \"src/components/**/*.vue\" \"src/composables/**/*.ts\" --ignore \"src/**/*.d.ts\" --out-file src/locales/en-US/options.json --preserve-whitespace",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "release:patch": "pnpm version patch && git push && git push --tags",
        "release:minor": "pnpm version minor && git push && git push --tags",
        "release:major": "pnpm version major && git push && git push --tags"
    },
    "dependencies": {
        "@fontsource-variable/inter": "^5.2.8",
        "@formatjs/intl": "^4.1.7",
        "@lucide/vue": "latest",
        "vue": "^3.5.33",
        "vue-i18n": "^11.4.0",
        "vue-router": "^5.0.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@formatjs/cli": "^6.14.3",
        "@tailwindcss/vite": "^4.2.4",
        "@types/node": "^22.19.17",
        "@wxt-dev/module-vue": "^1.0.3",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-vue": "^10.9.0",
        "prettier": "^3.8.3",
        "tailwindcss": "^4.2.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1",
        "vite-svg-loader": "^5.1.1",
        "vue-eslint-parser": "^10.4.0",
        "vue-tsc": "^3.2.7",
        "wxt": "^0.20.22"
    },
    "pnpm": {
        "patchedDependencies": {
            "wxt@0.20.22": "patches/wxt@0.20.22.patch"
        }
    }
}
