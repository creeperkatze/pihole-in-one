{
    "name": "pihole-in-one",
    "version": "1.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "zip": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "postinstall": "wxt prepare",
        "intl:extract": "formatjs extract \"src/entrypoints/popup/**/*.{vue,ts}\" --ignore \"src/**/*.d.ts\" --out-file src/locales/en-US/popup.json --preserve-whitespace && formatjs extract \"src/entrypoints/options/**/*.{vue,ts}\" \"src/components/**/*.vue\" \"src/composables/**/*.ts\" --ignore \"src/**/*.d.ts\" --out-file src/locales/en-US/options.json --preserve-whitespace",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "release:patch": "pnpm version patch && git push && git push --tags",
        "release:minor": "pnpm version minor && git push && git push --tags",
        "release:major": "pnpm version major && git push && git push --tags"
    },
    "dependencies": {
        "@formatjs/intl": "^3.0.0",
        "lucide-vue-next": "^1.0.0",
        "vue": "^3.5.13",
        "vue-i18n": "^10.0.0",
        "vue-router": "^5.0.4"
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "@formatjs/cli": "^6.2.12",
        "@tailwindcss/vite": "^4.2.2",
        "@types/node": "^22.10.2",
        "@wxt-dev/module-vue": "^1.0.3",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.2.1",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "eslint-plugin-vue": "^9.32.0",
        "prettier": "^3.4.2",
        "tailwindcss": "^4.2.2",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.18.2",
        "vue-tsc": "^2.2.0",
        "wxt": "^0.20.1"
    },
    "pnpm": {
        "patchedDependencies": {
            "wxt@0.20.20": "patches/wxt@0.20.20.patch"
        }
    }
}
