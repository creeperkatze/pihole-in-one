{
    "name": "pihole-in-one",
    "version": "1.3.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "zip": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "postinstall": "wxt prepare",
        "scripts": "node scripts/run.mjs",
        "intl:extract": "formatjs extract \"src/entrypoints/popup/**/*.{vue,ts}\" \"src/entrypoints/background.ts\" --ignore \"src/**/*.d.ts\" --out-file src/locales/en-US/popup.json --preserve-whitespace && formatjs extract \"src/entrypoints/options/**/*.{vue,ts}\" \"src/components/**/*.vue\" \"src/composables/**/*.ts\" --ignore \"src/**/*.d.ts\" --out-file src/locales/en-US/options.json --preserve-whitespace",
        "intl:generate": "pnpm scripts generate-locales",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "release:patch": "pnpm version patch && git push && git push --tags",
        "release:minor": "pnpm version minor && git push && git push --tags",
        "release:major": "pnpm version major && git push && git push --tags"
    },
    "dependencies": {
        "@fontsource-variable/inter": "^5.2.8",
        "@formatjs/intl": "^4.1.13",
        "@lucide/vue": "^1.18.0",
        "@wxt-dev/storage": "^1.2.8",
        "pihole-js": "^1.4.0",
        "vue": "^3.5.38",
        "vue-i18n": "^11.4.5",
        "vue-router": "^5.1.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@formatjs/cli": "^6.16.11",
        "@tailwindcss/vite": "^4.3.1",
        "@types/node": "^25.9.3",
        "@wxt-dev/module-vue": "^1.0.3",
        "eslint": "^10.5.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-vue": "^10.9.2",
        "prettier": "^3.8.4",
        "tailwindcss": "^4.3.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0",
        "vite-svg-loader": "^5.1.1",
        "vue-eslint-parser": "^10.4.1",
        "vue-tsc": "^3.3.5",
        "wxt": "^0.20.26"
    },
    "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
